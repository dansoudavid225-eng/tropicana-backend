# ─────────────────────────────────────────────────────────
#  Tropicana Pio Pio — Variables d'environnement Backend
#  Renommer ce fichier en  .env  et remplir les valeurs.
#  NE JAMAIS committer le fichier .env dans Git.
# ─────────────────────────────────────────────────────────

# Django
DJANGO_SECRET_KEY=remplacez-par-une-cle-aleatoire-longue-et-unique
# ⚠️ METTRE FALSE EN PRODUCTION — ne jamais déployer avec DEBUG=True
DEBUG=False

# Domaines autorisés (séparés par des virgules, sans espaces)
# Exemple production : ALLOWED_HOSTS=tropicanapiopio.com,www.tropicanapiopio.com
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Base de données PostgreSQL (laisser vide → SQLite en dev) ──
DB_NAME=tropicana_db
DB_USER=postgres
DB_PASSWORD=votre_mot_de_passe_postgres
DB_HOST=localhost
DB_PORT=5432

# ── Email SMTP Gmail ────────────────────────────────────────────
# Laisser vide → console en dev (emails affichés dans le terminal)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=tropicanapiopio.officiel@gmail.com
EMAIL_HOST_PASSWORD=votre_mot_de_passe_application_gmail

# ── Google OAuth ────────────────────────────────────────────────
# Obtenir sur https://console.cloud.google.com/
GOOGLE_CLIENT_ID=VOTRE_CLIENT_ID.apps.googleusercontent.com

# ── CORS — origines autorisées ──────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── FedaPay ────────────────────────────────────────────────
FEDAPAY_PUBLIC_KEY=pk_live_VOTRE_CLE_PUBLIQUE
FEDAPAY_SECRET_KEY=sk_live_VOTRE_CLE_SECRETE
FEDAPAY_ENV=
FEDAPAY_WEBHOOK_SECRET=
